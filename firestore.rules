rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // User profile & saldo: hanya owner yang bisa baca.
    // Tulis saldo HANYA via Admin SDK (server), client tidak boleh ubah tokenBalance.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if false; // saldo diubah server saja
      allow delete: if false;

      match /keys/{keyId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        // keyHash tidak boleh diubah client
        allow update: if isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['keyHash']);
        allow delete: if isOwner(uid);
      }

      match /usage/{usageId} {
        allow read: if isOwner(uid);
        allow write: if false; // hanya server
      }

      match /tx/{txId} {
        allow read: if isOwner(uid);
        allow write: if false; // hanya server
      }
    }
  }
}
